# Required for GitHub write access
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=your-org-or-user
GITHUB_REPO=your-repo

# Optional
GITHUB_BRANCH=main
FRONTEND_ORIGIN=http://localhost:5173
PORT=3001

# Optional schema source overrides
# Defaults point to:
# https://github.com/OS2borgerPC/sikker-selvbetjening/tree/main/system_files/usr/share/sikker-selvbetjening/schemas
GITHUB_SCHEMA_OWNER=OS2borgerPC
GITHUB_SCHEMA_REPO=sikker-selvbetjening
GITHUB_SCHEMA_BRANCH=main
GITHUB_SCHEMA_PATH=system_files/usr/share/sikker-selvbetjening/schemas
